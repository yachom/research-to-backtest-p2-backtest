# OpenDART API 인증키 — https://opendart.fss.or.kr 에서 발급
DART_API_KEY=

# ── LLM (Phase C에서만 필요 — Phase A·B는 LLM 없이 동작) ──────────────────
# 기본 경로: Claude Agent SDK + 구독 OAuth 토큰 (docs/MILESTONES.md D2 재개정)
# 발급: 별도 구독 계정으로 브라우저 로그인하며 `claude setup-token` 실행 → 1년 유효
# 토큰 출력(어디에도 저장 안 됨). 계정 ID/비밀번호는 절대 여기에 넣지 않는다.
CLAUDE_CODE_OAUTH_TOKEN=

# 대안 경로: Console API 키(별도 과금, 정책상 가장 명확한 경로).
# ⚠️ 주의: 인증 우선순위상 API 키 > OAuth 토큰 — 둘 다 설정하면 구독 대신
# API 과금이 된다. 반드시 하나만 설정할 것.
# ANTHROPIC_API_KEY=

# 폴백: OpenRouter 무료 모델 (일일 한도 작음 — https://openrouter.ai/keys)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=inclusionai/ling-2.6-flash:free

# KRX 정보데이터시스템 로그인 — https://data.krx.co.kr 무료 회원가입 (docs/MILESTONES.md D1 개정)
# 2025년부터 KRX가 데이터 조회에 로그인을 의무화해 투자자 수급·지수 수집에 필요하다.
# 수정주가 OHLCV는 로그인 없이도 수집된다.
KRX_ID=
KRX_PW=

# (후순위) 한국투자증권 KIS API — MVP는 pykrx 사용으로 불필요 (docs/MILESTONES.md D1)
# KIS_APP_KEY=
# KIS_APP_SECRET=

# (후순위) 토스증권 API 키 : 전략 시행 테스트 시 사용예정
CLIENT_ID=
CLIENT_SECRET=